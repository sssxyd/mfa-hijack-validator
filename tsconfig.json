{
  "compilerOptions": {
    "target": "ES2018",
    "module": "none",
    "lib": [
      "DOM",
      "ES2018"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "lib",
    "rootDir": "src",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*.ts"
  ]
}
